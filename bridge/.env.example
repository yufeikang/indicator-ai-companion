# Indicator 设备地址。本机裸跑可填 mDNS 名;Docker 容器内无 mDNS,填设备局域网 IP
INDICATOR_HOST=indicator-companion.local
# 必须 == firmware/secrets.yaml 里的 api_key
INDICATOR_NOISE_PSK=REPLACE_WITH_SECRETS_API_KEY

# 本地 hook 接收端(Claude Code hooks 往这里 POST)
BRIDGE_HTTP_HOST=127.0.0.1
BRIDGE_HTTP_PORT=9527

# HUD / 伴侣卡文案语言:zh / en(见 bridge/indicator_bridge/i18n.py)
BRIDGE_LANG=zh

# AI 伴侣卡:任意 OpenAI 兼容端点(本地 LM Studio / 局域网推理服务,免 key)
# 留空 COMPANION_API_KEY 即可;接 OpenAI 等需要鉴权的服务才填
COMPANION_BASE_URL=http://localhost:1234/v1
COMPANION_MODEL=your-local-model
COMPANION_API_KEY=
IDLE_SECONDS=90
COMPANION_INTERVAL=300
