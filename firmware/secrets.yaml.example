wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"
# 第二个 Wi-Fi(可选,多网络自动切换);只用一个网络可删掉这两行 + yaml 里的 networks 第二项
wifi_ssid_2: "YOUR_SECOND_WIFI_SSID"
wifi_password_2: "YOUR_SECOND_WIFI_PASSWORD"
# ESPHome 原生 API 加密 key。生成: openssl rand -base64 32
api_key: "REPLACE_WITH_BASE64_32BYTE_KEY"
